#!/bin/sh
# nullclaw-launch — wrapper that installs the gateway service on first run.

mkdir -p "$HOME/workspace"

# Install/refresh and enable the gateway service.  Re-copy the unit whenever the
# bundled copy changes (e.g. after a snap refresh) so updates actually land,
# rather than only installing once on the very first run.
SYSTEMD_USER_DIR="$HOME/.config/systemd/user"
mkdir -p "$SYSTEMD_USER_DIR"

install_service() {
  local name="$1"
  local unit_path="$SYSTEMD_USER_DIR/${name}.service"
  if [ ! -f "$unit_path" ] || ! cmp -s "$SNAP/share/systemd/user/${name}.service" "$unit_path"; then
    cp "$SNAP/share/systemd/user/${name}.service" "$unit_path"
    systemctl --user daemon-reload 2>/dev/null || true
  fi
  if ! systemctl --user is-enabled "$name" >/dev/null 2>&1; then
    systemctl --user enable --now "$name" 2>/dev/null || true
  fi
}

install_service nullclaw
install_service nullclaw-ui

exec "$SNAP/bin/nullclaw" "$@"
